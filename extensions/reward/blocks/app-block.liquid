{{ 'reward-style.css' | asset_url | stylesheet_tag }}

<div class="reward-dashboard">
  {% if customer %}
    <div class="reward-hero-banner">
      <div class="hero-left-content">
        <div class="hero-icon-box"><img src="{{ 'Group.png' | asset_url }}" alt="Icon" width="45" height="45" loading="lazy"></div>
        <div class="hero-content">
          <h2>{{ block.settings.hero_title | default: "Your Reward Points" }}</h2>
          <p>{{ block.settings.hero_subtitle | default: "You may redeem on your next purchase" }}</p>
        </div>
      </div>
      <div class="hero-illustration">
        {% if block.settings.hero_img != blank %}<img src="{{ block.settings.hero_img | image_url: width: 400 }}" alt="Illustration" height="285" width="412" loading="lazy">
        {% else %}
          <img src="{{ 'hero.png' | asset_url }}" alt="heroIllustration" height="285" width="412" loading="lazy">{% endif %}
      </div>
    </div>

    <div class="reward-summary-grid">
      <div class="summary-card">
        <div class="summary-info"><span>Total Reward Points Balance</span><strong id="summary-total-balance">0</strong></div>
        <div class="summary-icon">
          {% if block.settings.icon_balance != blank %}<img src="{{ block.settings.icon_balance | image_url: '100x' }}" alt="Icon" width="56" height="56" loading="lazy">
          {% else %}<img src="{{ 'wallet.png' | asset_url }}" alt="Wallet Icon" width="56" height="56" loading="lazy">{% endif %}
        </div>
      </div>
      <div class="summary-card">
        <div class="summary-info"><span>Lifetime Savings Till Date</span><strong id="summary-lifetime-savings">0</strong></div>
        <div class="summary-icon">
          {% if block.settings.icon_savings != blank %}<img src="{{ block.settings.icon_savings | image_url: '100x' }}" alt="Icon" width="56" height="56" loading="lazy">
          {% else %}<img src="{{ 'vector.png' | asset_url }}" alt="Savings Icon" width="56" height="56" loading="lazy">{% endif %}
        </div>
      </div>
    </div>

    <div class="history-container">
      <div class="history-header">
        <h3>Reward Points History</h3>
        <div class="header-points-summary">
          <div class="special-point-box"><span class="label">Birthday</span><span class="val" id="header-bday-points">0</span></div>
          <div class="special-point-box"><span class="label">Anniversary</span><span class="val" id="header-anniv-points">0</span></div>
          <div class="special-point-box"><span class="label">Pending Point</span><span class="val" id="header-pending-points">0</span></div>
          </div>
      </div>
      
      <div class="tab-menu">
        <div class="tab-item active" data-type="all" onclick="filterData('all', this)">All Activity</div>
        <div class="tab-item" data-type="earned" onclick="filterData('earned', this)">Earned</div>
        <div class="tab-item" data-type="redeemed" onclick="filterData('redeemed', this)">Redeemed</div>
      </div>

      <div id="activity-list">
        <div class="activity-loading" style="padding: 40px; text-align: center;">Fetching your activity...</div>
      </div>
    </div>

    <div class="reward-info-footer">
      <div class="redeem-banner">
        <div class="redeem-content">
          <h4>{{ block.settings.redeem_title | default: "How to Redeem" }}</h4>
          <p>{{ block.settings.redeem_desc | default: "Redeem your points during checkout..." }}</p>
        </div>
        <div class="redeem-image">
          {% if block.settings.redeem_img != blank %}<img src="{{ block.settings.redeem_img | image_url: width: 200 }}" alt="Redeem" width="200" height="96" loading="lazy">{% endif %}
        </div>
      </div>

      <div class="policy-section">
        <h4>{{ block.settings.policy_title | default: "Reward Points Policy" }}</h4>
        <ul>
          {% if block.settings.policy_1 != blank %}<li>{{ block.settings.policy_1 }}</li>{% endif %}
          {% if block.settings.policy_2 != blank %}<li>{{ block.settings.policy_2 }}</li>{% endif %}
          {% if block.settings.policy_3 != blank %}<li>{{ block.settings.policy_3 }}</li>{% endif %}
        </ul>
      </div>
    </div>
  {% else %}
    <p style="text-align: center; padding: 50px;">Please <a href="{{ routes.account_login_url }}">login</a> to see rewards.</p>
  {% endif %}
 <div class="referral-dashboard-card">
        <div class="referral-header">
          <div class="referral-icon-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7c4dff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="8.5" cy="7" r="4"></circle>
              <line x1="20" y1="8" x2="20" y2="14"></line>
              <line x1="23" y1="11" x2="17" y2="11"></line>
            </svg>
          </div>
          <div class="referral-title-content">
            <h3 class="ref-title">Invite Friends & Earn Points</h3>
            <p class="ref-subtitle">Earn points for every friend who joins (Max 5 friends).</p>
          </div>
        </div>

        <div class="referral-flex-container">
          
          <div id="referral-ui-active" class="referral-link-container">
            <label style="display:block; margin-bottom:8px; font-weight:600; font-size:14px;">Your Referral Link</label>
            <div class="referral-input-group">
              <input type="text" id="referral-link-input" readonly value="{{ shop.url }}?ref={{ customer.email }}">
              <button id="copy-referral-btn" onclick="handleCopyLink()">Copy Link</button>
            </div>
          </div>

          <div class="referral-status-area">
            <div class="status-labels">
              <span id="referral-count-label">Successful Referrals: 0 / 5</span>
              <span id="referral-points-label">Points Earned: 0</span>
            </div>
            <div class="progress-track">
              <div id="referral-progress-bar"></div>
            </div>
            <p id="referral-limit-msg" style="margin-top: 8px; font-size: 13px;"></p>
          </div>

        </div>
      </div>
    </div>

<script>
  let allOrders = [];
  let currentFilter = 'all';

document.addEventListener("DOMContentLoaded", async function() {
    {% if customer %}
      const proxyPath = `/apps/public/campgin`; 
      const fetchUrl = `${proxyPath}?logged_in_customer_id={{ customer.id }}&shop={{ shop.permanent_domain }}`;
      
      try {
        const response = await fetch(fetchUrl);
        const result = await response.json();
        
        if (result.status === "success") {
          allOrders = result.orders || [];
          document.getElementById('summary-total-balance').innerText = result.totalPoints || 0;

          // 2. Lifetime Savings update karein (No status condition needed here)
          const savingsEl = document.getElementById('summary-lifetime-savings');
          if (savingsEl) {
              savingsEl.innerText = result.lifetimeSavings || 0;
          }

          if (document.getElementById('header-bday-points')) {
              document.getElementById('header-bday-points').innerText = result.birthdayPoint || 0;
          }
          if (document.getElementById('header-anniv-points')) {
              document.getElementById('header-anniv-points').innerText = result.anniversaryPoint || 0;
          }

          const pendingEl = document.getElementById('header-pending-points');
          if (pendingEl) {
            pendingEl.innerText = result.promisedPoints || 0;
          }
          renderList(allOrders, 'all');
        }
      } catch (e) { 
        console.error("Fetch error:", e);
      }
    {% endif %}
  });

function renderList(orders, filterType) {
    const container = document.getElementById('activity-list');
    let htmlContent = '';

    if (!orders || orders.length === 0) { 
      container.innerHTML = `<div style="padding:40px; text-align:center;">No records found.</div>`; 
      return; 
    }

    orders.forEach(order => {
      if (order.status === 'CANCELLED') return;

      // Pending points ko 'earned' filter mein bhi dikhayein
      const isEarned = order.type === 'earned' || order.status === 'PENDING';
      const isRedeemed = order.type === 'redeemed';

      if (filterType === 'all' || 
          (filterType === 'earned' && isEarned) || 
          (filterType === 'redeemed' && isRedeemed)) {
        
        htmlContent += createActivityRow(
          order.description, 
          order.createdAt, 
          order.points, 
          order.type,
          order.status // Yeh status pass karna zaroori hai
        );
      }
    });

    container.innerHTML = htmlContent || `<div style="padding:40px; text-align:center;">No ${filterType} records.</div>`;
}

function createActivityRow(title, dateStr, points, type, status) {
    const date = new Date(dateStr).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });
    
    let badgeClass = '';
    let badgeText = '';

    // Grey color pending points ke liye
    if (status === 'PENDING') {
        badgeClass = 'badge-pending-grey'; 
        badgeText = 'Pending Point';
    } else if (type === 'earned') {
        badgeClass = 'badge-earned';
        badgeText = 'Earned Points';
    } else {
        badgeClass = 'badge-used';
        badgeText = 'Used Points';
    }
    
    return `<div class="activity-item">
      <div class="activity-left">
        <div class="activity-icon"><img src="{{ 'Group.png' | asset_url }}" width="42" height="42" loading="lazy"></div>
        <div class="activity-info">
          <div style="font-weight:700; font-size:18px; color:#374151;">${title}</div>
          <div class="meta" style="display:flex; gap:20px; align-items:center;">
            <span>${date}</span>
            <span class="badge ${badgeClass}">${badgeText}</span>
          </div>
        </div>
      </div>
      <div class="activity-right">
        <div class="points-value">${points}</div>
        <div class="points-label">Points</div>
      </div>
    </div>`;
}

  function filterData(type, el) {
    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    currentFilter = type;
    renderList(allOrders, type);
  }
</script>


<script>
/**
 * Synchronizes the UI with the latest referral data from the backend.
 */
async function syncReferralDashboard() {
  const customerId = "{{ customer.id }}";
  if (!customerId) return;

  try {
    const response = await fetch(`/apps/public/referral-data?logged_in_customer_id=${customerId}`);
    const data = await response.json();

    const currentCount = data.referralCount || 0;
    const referralPoints = data.referralPoint || 0; 
    const maxLimit = 5;

    const countLabel = document.getElementById('referral-count-label');
    const pointsLabel = document.getElementById('referral-points-label');
    const progressBar = document.getElementById('referral-progress-bar');
    const limitMsg = document.getElementById('referral-limit-msg');
    const referralUiActive = document.getElementById('referral-ui-active');

    if (countLabel) countLabel.innerText = `Successful Referrals: ${currentCount} / ${maxLimit}`;
    if (pointsLabel) pointsLabel.innerText = `Points Earned: ${referralPoints}`;
    
    if (progressBar) {
      const progressPercentage = (currentCount / maxLimit) * 100;
      progressBar.style.width = `${progressPercentage}%`;
    }

    if (limitMsg) {
      limitMsg.style.display = "block";
      
      if (currentCount >= maxLimit) {
        limitMsg.style.color = "#d72c0d"; 
        limitMsg.innerText = "You have reached your limit of 5 successful referrals.";
        if (referralUiActive) {
          referralUiActive.style.display = "none";
        }
      } else {
        limitMsg.style.color = "#008060";
        limitMsg.innerText = `Refer ${maxLimit - currentCount} more friends to earn more points!`;
        if (referralUiActive) {
          referralUiActive.style.display = "block";
        }
      }
    }
  } catch (err) {
    console.error(">>> [ERROR] Referral Sync Failed:", err);
  }
}

function handleCopyLink() {
  const linkInput = document.getElementById('referral-link-input');
  const copyBtn = document.getElementById('copy-referral-btn');
  
  if (copyBtn.disabled) return;

  linkInput.select();
  linkInput.setSelectionRange(0, 99999);
  navigator.clipboard.writeText(linkInput.value);

  const originalText = copyBtn.innerText;
  copyBtn.innerText = "Copied!";
  copyBtn.style.background = "#008060";
  
  setTimeout(() => {
    copyBtn.innerText = originalText;
    copyBtn.style.background = "#7c4dff";
  }, 2000);
}
document.addEventListener("DOMContentLoaded", syncReferralDashboard);
</script>

{% schema %}
{
  "name": "Reward Order History",
  "target": "section",
  "settings": [
    { "type": "header", "content": "Hero Banner" },
    { "type": "image_picker", "id": "hero_img", "label": "Hero Banner Illustration" },
    { "type": "text", "id": "hero_title", "label": "Hero Title", "default": "Your Reward Points" },
    { "type": "text", "id": "hero_subtitle", "label": "Hero Subtitle", "default": "You may redeem on your next purchase" },
    { "type": "header", "content": "Summary Card Icons" },
    { "type": "image_picker", "id": "icon_balance", "label": "Total Balance Icon" },
    { "type": "image_picker", "id": "icon_savings", "label": "Lifetime Savings Icon" },
    { "type": "header", "content": "How to Redeem" },
    { "type": "text", "id": "redeem_title", "label": "Redeem Title", "default": "How to Redeem" },
    { "type": "textarea", "id": "redeem_desc", "label": "Redeem Description", "default": "Redeem your points during checkout..." },
    { "type": "image_picker", "id": "redeem_img", "label": "Redeem Illustration Image" },
    { "type": "header", "content": "Reward Policy" },
    { "type": "text", "id": "policy_title", "label": "Policy Title", "default": "Reward Points Policy" },
    { "type": "text", "id": "policy_1", "label": "Policy Line 1", "default": "Maximum points value cannot exceed order value" },
    { "type": "text", "id": "policy_2", "label": "Policy Line 2", "default": "Reward Points never expire" },
    { "type": "text", "id": "policy_3", "label": "Policy Line 3", "default": "Non-transferable between accounts" }
  ]
}
{% endschema %}